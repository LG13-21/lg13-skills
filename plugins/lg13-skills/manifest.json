  "loader_protocol": {
    "doc": "How session_manager.py --lazy-skills uses this manifest.",
    "steps": [
      "1. Read manifest.json",
      "2. Compute hot set = hot.skills + (if instance==strat: hot_strat_only.skills)",
      "3. Inject hot SKILL.md contents into session context",
      "4. Cold skills not loaded — surfaced only when: (a) user message matches trigger keyword via simple substring/regex, (b) explicit /lg13-skills:<name> invocation, (c) Skill tool called by name",
      "5. On cold trigger: load that single SKILL.md, mark as 'warm' (resident for rest of session)",
      "6. After /compact, warm set resets — only hot remains"
    ],
    "fallback": "If manifest.json missing or malformed → load all skills (eager mode, current behavior)."
  }
